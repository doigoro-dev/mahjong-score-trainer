{
  "name": "mahjong-score-trainer",
  "version": "1.6.0",
  "private": true,
  "scripts": {
    "test": "npm run test:static-data && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:static-data": "node scripts/static-data-check.mjs",
    "test:smoke": "playwright test tests/e2e/01-startup.spec.ts tests/e2e/02-answer.spec.ts",
    "test:responsive": "playwright test tests/e2e/05-responsive.spec.ts",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "http-server": "^14.1.1",
    "typescript": "^5.9.2"
  }
}
